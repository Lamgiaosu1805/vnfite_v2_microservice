# ══════════════════════════════════════════════════════════════════
#  P2P Lending — Environment Variables
#  Copy to .env and fill in your values:  cp .env.example .env
#
#  Cách nhanh nhất: chạy ./setup.sh — script tự generate RSA key
#  và tạo .env với giá trị mặc định (chạy local hoàn toàn).
# ══════════════════════════════════════════════════════════════════

# ─── Woodpecker CI (docker-compose.ci.yml) ────────────────────────
# Tạo GitHub OAuth App tại: https://github.com/settings/developers
#   Homepage URL:       http://42.113.122.119:3000
#   Callback URL:       http://42.113.122.119:3000/authorize
WOODPECKER_GITHUB_CLIENT=your-github-oauth-client-id
WOODPECKER_GITHUB_SECRET=your-github-oauth-client-secret
# Tự generate: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=replace-with-random-32-char-string
WOODPECKER_ADMIN=Lamgiaosu1805
SERVER_IP=42.113.122.119

# ─── Spring Profile ───────────────────────────────────────────────
# dev  → load migration + seed data (dành cho developer local)
# prod → chỉ load migration, không có seed data (dành cho server test/live)
SPRING_PROFILES_ACTIVE=dev

# ─── MySQL ────────────────────────────────────────────────────────
# Để trống → dùng MySQL container trong docker-compose (khuyến nghị khi chạy local)
# Điền IP/hostname nếu muốn trỏ tới DB server riêng
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ─── Per-service databases ────────────────────────────────────────
AUTH_DB=auth_db
LOAN_DB=loan_db
CMS_DB=cms_db
MATCHING_DB=matching_db
PAYMENT_DB=payment_db
NOTIFICATION_DB=notification_db
CREDIT_DB=credit_db

# ─── Database credentials ─────────────────────────────────────────
# Giá trị mặc định khớp với MySQL container trong docker-compose.yml
# Đổi nếu trỏ tới DB server riêng
DB_USERNAME=p2p_user
DB_PASSWORD=p2p_pass

# ─── Redis ────────────────────────────────────────────────────────
# Khi chạy qua docker-compose, services nội bộ dùng hostname "redis"
# Giá trị này chỉ dùng khi chạy service thẳng trên host (không qua Docker)
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ────────────────────────────────────────────────────────
# Tương tự Redis — hostname "kafka" dùng trong docker network
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── RSA Key Pair (JWT RS256) — BẮT BUỘC phải điền ──────────────
# Chạy ./setup.sh để tự động generate, HOẶC làm thủ công:
#
#   openssl genrsa -out private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private.pem -out private_pkcs8.pem
#   openssl rsa -in private.pem -pubout -out public.pem
#
#   RSA_PRIVATE_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' private_pkcs8.pem)
#   RSA_PUBLIC_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' public.pem)
#
# Dán kết quả vào đây (1 dòng, dùng \n thay cho xuống dòng thật):
RSA_PRIVATE_KEY=REPLACE_WITH_BASE64_PKCS8_PRIVATE_KEY
RSA_PUBLIC_KEY=REPLACE_WITH_BASE64_X509_PUBLIC_KEY

# ─── CMS admin users — TÁCH RIÊNG customer login ─────────────────
# cms-service tự seed tài khoản quản trị đầu tiên nếu username chưa tồn tại.
CMS_JWT_SECRET=replace-with-at-least-32-bytes-cms-secret
CMS_ACCESS_TOKEN_EXPIRY=28800
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSWORD=Admin@123456
CMS_ADMIN_EMAIL=admin@p2plending.local
CMS_ADMIN_FULL_NAME=CMS Administrator

# ─── Internal service-to-service calls ────────────────────────────
# Dùng chung giữa cms-service, auth-service và loan-service.
INTERNAL_API_SECRET=replace-with-random-internal-secret
AUTH_SERVICE_URL=http://auth-service:8081
LOAN_SERVICE_URL=http://loan-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8086
CREDIT_SERVICE_URL=http://credit-service:8087

# ─── Tin tức VNFITE ───────────────────────────────────────────────
# loan-service ghi ảnh news ra volume host này, nginx public qua /images/news/*
APP_NEWS_IMAGE_DIR=/var/www/html/images/news
APP_NEWS_PUBLIC_BASE=http://localhost:7080

# ─── TIKLUY-ms002 (MB Bank integration) ──────────────────────────
# TIKLUY là service trung gian với MB Bank, chạy ở IP được MB whitelist.
#
# ⚠️ AN TOÀN TIỀN THẬT: TIKLUY LIVE (42.113.122.155:8888, IS_PROD=Y) gọi MB Bank THẬT và
#    chuyển tiền thật. Mặc định TIKLUY_BASE_URL trỏ TEST để tránh chạm tiền thật. Chỉ đổi
#    sang live khi go-production và đã xác nhận rõ ràng.
#
# Môi trường:
#   Local dev  → APP_PAYMENT_MOCK=true, TIKLUY_BASE_URL không quan trọng
#   Test server (42.113.122.119) → TIKLUY chạy trên 42.113.122.119:9999 (IS_PROD=N, MB sandbox)
#   Live server (42.113.122.118) → TIKLUY chạy trên 42.113.122.155:8888 (MB whitelist, TIỀN THẬT)
#
# Để chạy nạp/rút/tạo tài khoản định danh THẬT trên test (sandbox, không chạm tiền thật):
#   APP_PAYMENT_MOCK=false
#   TIKLUY_BASE_URL=http://42.113.122.119:9999   (+ TIKLUY app.url=http://42.113.122.119:8086)
APP_PAYMENT_MOCK=true
TIKLUY_BASE_URL=http://42.113.122.119:9999
TIKLUY_CLIENT_ID=VF-NSK3SDF
TIKLUY_CLIENT_SECRET=2tzMGst67sZfXqmx68TxnQUzyriBti
TIKLUY_SOURCE=VNFITE
# Secret này phải giống VNFITE_NEW_CALLBACK_SECRET trên account-service 8888.
# Có thể để trống trong UAT nếu đã khóa IP 42.113.122.155 ở nginx + allowlist dưới đây.
TIKLUY_CALLBACK_SECRET=
TIKLUY_CALLBACK_ALLOWED_IPS=42.113.122.155,127.0.0.1

# ─── Credit Scoring AI (credit-service) ──────────────────────────
# AI risk assessment — chỉ TƯ VẤN cho admin thẩm định, không tự quyết định duyệt/từ chối.
# Để bật trên test server: set APP_AI_ENABLED=true + APP_AI_MODE=demo (không cần API key)
# hoặc APP_AI_MODE=gemini + GEMINI_API_KEY (miễn phí tại aistudio.google.com/apikey)
APP_AI_ENABLED=false
# Mode khi enabled=true:
#   demo   → fake realistic, không cần API key (dùng để test UI, default khi không set)
#   gemini → Gemini Flash thật, miễn phí (cần GEMINI_API_KEY)
#   claude → Claude API thật (cần ANTHROPIC_API_KEY)
APP_AI_MODE=demo
ANTHROPIC_API_KEY=
APP_AI_MODEL=claude-opus-4-8
# Gemini (chỉ cần khi APP_AI_MODE=gemini)
# Lấy key miễn phí tại: aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# File-manager dùng chung — nơi lưu chứng từ gốc (app upload, credit-service fetch lại)
FILE_MANAGER_URL=https://service.vnfite.com.vn/file-manager/v2

# ─── Email / SMTP (notification-service) ─────────────────────────
# Dùng Gmail: bật "App Password" tại myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
