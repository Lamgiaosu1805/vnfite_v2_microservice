# ─── Kafka ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── RSA Key Pair (JWT RS256) ─────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then inline the PEM (replace newlines with \n):
#   RSA_PRIVATE_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' private.pem)
#   RSA_PUBLIC_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' public.pem)
#
# Paste the result here (single line, with literal \n):
RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----\n

# ─── Email / SMTP (notification-service) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
